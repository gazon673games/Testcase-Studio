{
  "name": "testcase-studio",
  "productName": "Testcase Studio",
  "description": "Desktop app for editing manual test cases and syncing them with Zephyr Scale.",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "cross-env ELECTRON_RENDERER_URL=http://localhost:5173 vite --config vite.renderer.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build --config vite.renderer.config.ts",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "audit:readability": "node tools/readability-audit.mjs"
  },
  "dependencies": {
    "keytar": "^7.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.28.3",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.2"
  }
}
